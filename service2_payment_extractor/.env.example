# =============================================================================
# Service 2 - 付款信息提取服务 环境变量示例
# 复制为 .env 后按需修改。所有变量均为可选，缺省值已在代码中定义。
# =============================================================================

# ----- 应用 -----
ENVIRONMENT=production
MAX_WORKERS=5
LOG_DIR=./logs
LOG_ENABLE_FILE=true
LOG_CONSOLE_LEVEL=INFO
# S3 修复：示例默认 INFO，避免 DEBUG 级日志在生产环境落盘合同原文。
# 仅在开发排障时临时切回 DEBUG。
LOG_FILE_LEVEL=INFO
# S3 修复：production 环境强制脱敏；显式置 0 可关闭脱敏便于本地排障。
LOG_REDACT_PII=1
LOG_ROTATION=10 MB
LOG_COMPRESSION=zip
LOG_RETENTION=

# ----- 服务行为 -----
REQUEST_TIMEOUT_SEC=300
MAX_PARAGRAPHS=200
MAX_CLAUSE_LEN=10000
SERVICE2_DEBUG_SNAPSHOT=0

# ----- LLM 默认配置 -----
LLM_MODEL=
LLM_MODEL_NAME=
# 可选：无鉴权网关（如百舸内部网关）留空即可；千帆等需鉴权平台请填写真实 Key
LLM_API_KEY=
LLM_API_BASE=
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=8192
LLM_REQUEST_TIMEOUT_SEC=60
LLM_MAX_RETRIES=2
LLM_CONCURRENCY=16
LLM_CALL_TIMEOUT_SEC=60

# ----- 比例提取专用 LLM（可空，为空则继承默认） -----
PAYMENT_RATIO_LLM_MODEL=
# 可选：无鉴权网关留空即可
PAYMENT_RATIO_LLM_API_KEY=
PAYMENT_RATIO_LLM_API_BASE=
PAYMENT_RATIO_LLM_TEMPERATURE=

# ----- RAG 配置 -----
RAG_USE_REMOTE_EMBEDDING=true
RAG_REMOTE_EMBEDDING_URL=
RAG_REMOTE_EMBEDDING_KEY=
RAG_REMOTE_EMBEDDING_MODEL=qwen3-embedding-0.6b
RAG_EMBEDDING_DIMENSION=1024

USE_BM25=true
USE_VECTOR=true
USE_RERANK=false
RAG_TOP_K=5

RAG_BM25_MIN_SCORE=20.0
RAG_VECTOR_MIN_DISTANCE=0.5

EMBED_CONCURRENCY=4
EMBED_MAX_RETRIES=3

RAG_MILVUS_URI=
RAG_MILVUS_HOST=
RAG_MILVUS_PORT=
RAG_SEARCH_METRIC=COSINE
RAG_COLLECTION_NAME=
RAG_COLLECTION_NAME_INSTALLATION=

# ----- 去重 / 上下文合并 阈值 -----
DEDUPE_CONTEXT_SIM=0.85
DEDUPE_CONTEXT_OVERLAP=20
DEDUPE_ITEM_SIM_STRICT=0.95
DEDUPE_ITEM_SIM_LOOSE=0.8

# ----- BM25 资源 -----
RAG_BM25_LOCAL_DIR=
RAG_BM25_BOS_BUCKET=smec-ai-model-bos
RAG_BM25_BOS_REMOTE_DIR=
RAG_BM25_LOCAL_DIR_INSTALLATION=
RAG_BM25_BOS_BUCKET_INSTALLATION=smec-ai-model-bos
RAG_BM25_BOS_REMOTE_DIR_INSTALLATION=
BM25_REQUIRE_HASH=0

# ----- BOS 通用 -----
BOS_ACCESS_KEY=
BOS_SECRET_KEY=
BOS_ENDPOINT=
BOS_BUCKET_NAME=smec-ai-model-bos
BOS_PRESIGN_TTL_SEC=86400

# ----- 条款过滤 -----
CLAUSE_FILTER_KEYWORDS=违约金,罚款,赔偿损失

# ----- 可观测（可选，依赖 observability extras） -----
ENABLE_PROMETHEUS=0
OTEL_EXPORTER_OTLP_ENDPOINT=
